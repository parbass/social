<odoo>
    <template id="contact" inherit_id="base.contact" name="Forum Contact Widget">
        <xpath expr="//span[@itemprop='website']/../.." position="after">
            <div
                class="d-flex align-items-baseline gap-1"
                t-if="object.social_linkedin"
            >
                <i
                    t-if="not options.get('no_marker')"
                    class='fa fa-linkedin fa-fw'
                    role="img"
                    aria-label="LinkedIn"
                    title="LinkedIn"
                />
                <a
                    class="text-break w-100"
                    target="_blank"
                    t-att-href="object.social_linkedin and '%s%s' % ('https://' if '://' not in object.social_linkedin else '', object.social_linkedin)"
                >
                    <span itemprop="social_linkedin" t-esc="object.social_linkedin" />
                </a>
            </div>
        </xpath>
    </template>
</odoo>
